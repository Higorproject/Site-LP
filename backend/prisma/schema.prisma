generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id           String   @id @default(cuid())
  name         String
  company      String
  email        String
  phone        String
  interestArea String
  message      String
  status       String   @default("Novo")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
